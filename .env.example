# ForgeSchool — environment variables template.
#
# Copy this file to .env.local and fill in every value before running `pnpm dev`.
# Never commit .env.local. Never put production secrets in any .env file checked
# into git. This file is the exhaustive list of every env var this app reads.
#
# Variables prefixed with PUBLIC_ are exposed to the browser via
# $env/static/public. Everything else is server-only via $env/static/private.

# ─── Application ─────────────────────────────────────────────────────────────
# NODE_ENV is set by SvelteKit automatically; do not override here.

# Canonical origin. Used for OG tags, canonical URLs, Stripe success/cancel URLs.
PUBLIC_APP_URL="http://localhost:5173"

# Public product name for meta tags, page titles, transactional emails.
PUBLIC_APP_NAME="ForgeSchool"

# ─── Database (Postgres 16 via Docker Compose locally) ───────────────────────
# Format: postgres://user:password@host:port/database
DATABASE_URL="postgres://forgeschool:forgeschool@localhost:5432/forgeschool"

# ─── Stripe (TEST MODE ONLY on v1) ───────────────────────────────────────────
# Get these from https://dashboard.stripe.com/test/apikeys. Keys must start with
# sk_test_ / pk_test_ — the app refuses to boot with live keys in v1.
STRIPE_SECRET_KEY="sk_test_replace_me"
PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_replace_me"

# Stripe CLI prints this when you run `stripe listen --forward-to localhost:5173/api/webhooks/stripe`.
# Rotates every time the CLI restarts; update .env.local accordingly.
STRIPE_WEBHOOK_SECRET="whsec_replace_me"

# ─── Observability ───────────────────────────────────────────────────────────
# Server-side Sentry DSN (errors from hooks.server.ts and +server.ts endpoints).
SENTRY_DSN=""

# Client-side Sentry DSN. May be the same project, may be a separate one.
PUBLIC_SENTRY_DSN=""

# pino log level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL="info"

# ─── Analytics ───────────────────────────────────────────────────────────────
# The bare domain Plausible counts against. Empty disables the tracker in dev.
PUBLIC_PLAUSIBLE_DOMAIN=""

# ─── Transactional email (Resend test account for v1) ────────────────────────
# https://resend.com/api-keys — use a test key; domain must be verified for sending.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="hello@forgeschool.dev"
